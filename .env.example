# FHE-EPMC environment template.
# Copy to .env.local for local development. NEVER commit .env.local.
# All secrets are server-only — none of these are exposed to the browser.

# GitHub personal access token or app installation token used by the typed
# service layer to query PRs / checks / branch protection. Server-only.
# Required scopes (PAT): repo, read:org. App tokens preferred in production.
GITHUB_TOKEN=

# Optional: explicit GitHub API base for GitHub Enterprise Server. Leave blank
# for github.com.
GITHUB_API_URL=

# Optional: comma-separated allowlist of repo slugs (owner/name) the dashboard
# is permitted to query. If empty, the registry config is the source of truth.
PORTFOLIO_ALLOWLIST=
