{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "nextjs",
  "installCommand": "npm ci || npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "ignoreCommand": "bash scripts/vercel-ignore.sh",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "github": {
    "enabled": true,
    "autoAlias": true,
    "autoJobCancelation": true,
    "silent": false
  },
  "regions": ["lhr1"],
  "cleanUrls": true,
  "trailingSlash": false
}
